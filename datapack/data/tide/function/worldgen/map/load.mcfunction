# hold the structure dimensions
scoreboard objectives add tide.worldgen.map.dim.x dummy
scoreboard objectives add tide.worldgen.map.dim.z dummy
scoreboard objectives add tide.worldgen.map.pad dummy

# hold the structure's minimum X/Z corner in ocean block coordinates
scoreboard objectives add tide.worldgen.map.pos.x dummy
scoreboard objectives add tide.worldgen.map.pos.z dummy

# hold the template placement anchor after rotation
scoreboard objectives add tide.worldgen.map.place.x dummy
scoreboard objectives add tide.worldgen.map.place.z dummy

# hold exact and padded reservation bounds
scoreboard objectives add tide.worldgen.map.min.x dummy
scoreboard objectives add tide.worldgen.map.max.x dummy
scoreboard objectives add tide.worldgen.map.min.z dummy
scoreboard objectives add tide.worldgen.map.max.z dummy
scoreboard objectives add tide.worldgen.map.rmin.x dummy
scoreboard objectives add tide.worldgen.map.rmax.x dummy
scoreboard objectives add tide.worldgen.map.rmin.z dummy
scoreboard objectives add tide.worldgen.map.rmax.z dummy

# holds the type of structure
scoreboard objectives add tide.worldgen.map.type dummy

# layout state
scoreboard objectives add tide.worldgen.map.rotation dummy
scoreboard objectives add tide.worldgen.map.attempt dummy
scoreboard objectives add tide.worldgen.map.tmp dummy
